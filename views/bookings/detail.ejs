<% layout('/layouts/boilerplate') -%>

<style>
  .detail-card {
    background: #fff; border-radius: 20px; padding: 2.5rem;
    box-shadow: 0 8px 40px rgba(15,23,42,0.08); max-width: 680px; margin: 2rem auto;
  }
  .detail-title { font-size: 1.6rem; font-weight: 700; color: #1f2933; margin-bottom: 1.5rem; }
  .detail-row { display: flex; justify-content: space-between; padding: 0.8rem 0; border-bottom: 1px solid #f1f5f9; font-size: 0.95rem; }
  .detail-row:last-child { border-bottom: none; }
  .detail-label { color: #6b7280; font-weight: 500; }
  .detail-value { font-weight: 600; color: #1f2933; text-align: right; }
  .status-badge { display: inline-block; padding: 4px 14px; border-radius: 999px; font-size: 0.8rem; font-weight: 700; }
  .status-paid { background: #f0fdf4; color: #15803d; }
  .status-upcoming { background: #eff6ff; color: #1d4ed8; }
  .status-cancelled { background: #fef2f2; color: #b91c1c; }
  .listing-preview { border-radius: 14px; overflow: hidden; margin-bottom: 1.5rem; position: relative; }
  .listing-preview img { width: 100%; height: 180px; object-fit: cover; }
  .listing-preview-overlay { position: absolute; bottom: 0; left: 0; right: 0; padding: 1rem; background: linear-gradient(transparent, rgba(0,0,0,0.6)); color: #fff; }
  .razorpay-id { font-size: 0.75rem; color: #9ca3af; word-break: break-all; }
</style>

<div class="detail-card">
  <a href="/bookings/my" style="color:#6b7280;font-size:0.88rem;display:inline-flex;align-items:center;gap:6px;margin-bottom:1.2rem;text-decoration:none;">
    <i class="fa-solid fa-arrow-left"></i> Back to My Bookings
  </a>

  <h2 class="detail-title">Booking Details</h2>

  <!-- Listing preview -->
  <% if (booking.listing) { %>
    <div class="listing-preview">
      <img src="<%= booking.listing.image?.url || booking.listing.image || '/images/placeholder.jpg' %>"
        alt="<%= booking.listing.title %>">
      <div class="listing-preview-overlay">
        <a href="/listings/<%= booking.listing._id %>" style="color:#fff;font-weight:700;font-size:1.05rem;text-decoration:none;">
          <%= booking.listing.title %>
        </a>
        <p style="margin:2px 0 0;font-size:0.85rem;opacity:0.85;">
          <%= booking.listing.location %>, <%= booking.listing.country %>
        </p>
      </div>
    </div>
  <% } %>

  <!-- Booking info -->
  <div>
    <div class="detail-row">
      <span class="detail-label">Booking ID</span>
      <span class="detail-value razorpay-id"><%= booking._id %></span>
    </div>
    <div class="detail-row">
      <span class="detail-label">Check-in</span>
      <span class="detail-value"><%= new Date(booking.checkIn).toLocaleDateString('en-IN', {weekday:'short', day:'numeric', month:'long', year:'numeric'}) %></span>
    </div>
    <div class="detail-row">
      <span class="detail-label">Check-out</span>
      <span class="detail-value"><%= new Date(booking.checkOut).toLocaleDateString('en-IN', {weekday:'short', day:'numeric', month:'long', year:'numeric'}) %></span>
    </div>
    <div class="detail-row">
      <span class="detail-label">Duration</span>
      <span class="detail-value"><%= booking.nights %> night<%= booking.nights !== 1 ? 's' : '' %></span>
    </div>
    <div class="detail-row">
      <span class="detail-label">Guests</span>
      <span class="detail-value"><%= booking.guests %> guest<%= booking.guests !== 1 ? 's' : '' %></span>
    </div>
    <div class="detail-row">
      <span class="detail-label">Total Paid</span>
      <span class="detail-value" style="font-size:1.15rem;color:var(--primary);">₹<%= booking.totalPrice?.toLocaleString('en-IN') %></span>
    </div>
    <div class="detail-row">
      <span class="detail-label">Payment Status</span>
      <span class="detail-value">
        <span class="status-badge status-<%= booking.paymentStatus %>"><%= booking.paymentStatus %></span>
      </span>
    </div>
    <div class="detail-row">
      <span class="detail-label">Booking Status</span>
      <span class="detail-value">
        <span class="status-badge status-<%= booking.status %>"><%= booking.status %></span>
      </span>
    </div>
    <% if (booking.razorpayPaymentId) { %>
      <div class="detail-row">
        <span class="detail-label">Razorpay Payment ID</span>
        <span class="detail-value razorpay-id"><%= booking.razorpayPaymentId %></span>
      </div>
    <% } %>
    <div class="detail-row">
      <span class="detail-label">Booked On</span>
      <span class="detail-value"><%= new Date(booking.createdAt).toLocaleDateString('en-IN', {day:'numeric', month:'long', year:'numeric'}) %></span>
    </div>
  </div>

  <div style="margin-top:1.5rem;display:flex;gap:10px;">
    <a href="/listings/<%= booking.listing?._id %>" class="hk-btn">View Listing</a>
    <% if (booking.status === 'upcoming' && booking.paymentStatus === 'paid') { %>
      <form method="POST" action="/bookings/<%= booking._id %>/cancel"
        onsubmit="return confirm('Cancel this booking? This cannot be undone.');">
        <button type="submit" class="hk-btn" style="background:#ef4444;border-color:#ef4444;">Cancel Booking</button>
      </form>
    <% } %>
  </div>
</div>
