<% layout('/layouts/boilerplate') -%>

<style>
  .bookings-header { margin: 2rem 0 1.5rem; }
  .bookings-header h2 { font-size: 1.8rem; font-weight: 700; color: #1f2933; }
  .bookings-header p { color: #6b7280; font-size: 0.95rem; }

  .booking-card {
    background: #fff;
    border-radius: 16px;
    border: 1.5px solid #e3e5ec;
    padding: 1.4rem 1.6rem;
    margin-bottom: 1rem;
    display: flex;
    gap: 1.4rem;
    align-items: flex-start;
    transition: box-shadow 0.18s;
  }
  .booking-card:hover { box-shadow: 0 8px 30px rgba(15,23,42,0.08); }

  .booking-thumb {
    width: 110px;
    height: 90px;
    border-radius: 12px;
    object-fit: cover;
    flex-shrink: 0;
  }

  .booking-info { flex: 1; min-width: 0; }
  .booking-title { font-size: 1.05rem; font-weight: 700; color: #1f2933; margin-bottom: 4px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .booking-location { font-size: 0.85rem; color: #6b7280; margin-bottom: 8px; }
  .booking-dates { font-size: 0.88rem; color: #374151; margin-bottom: 6px; }
  .booking-meta { display: flex; gap: 10px; flex-wrap: wrap; align-items: center; }

  .status-badge {
    display: inline-block;
    padding: 3px 12px;
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .status-upcoming { background: #eff6ff; color: #1d4ed8; }
  .status-paid { background: #f0fdf4; color: #15803d; }
  .status-completed { background: #f3f4f6; color: #374151; }
  .status-cancelled { background: #fef2f2; color: #b91c1c; }
  .status-failed { background: #fef2f2; color: #b91c1c; }

  .booking-price { font-size: 1rem; font-weight: 700; color: #1f2933; }
  .booking-actions { display: flex; gap: 8px; margin-top: 10px; }
  .btn-sm-outline {
    padding: 5px 14px; border-radius: 8px; font-size: 0.82rem; font-weight: 600;
    border: 1.5px solid #e3e5ec; background: #fff; color: #374151; cursor: pointer;
    text-decoration: none; display: inline-block; transition: all 0.15s;
  }
  .btn-sm-outline:hover { border-color: var(--primary); color: var(--primary); text-decoration: none; }
  .btn-sm-danger {
    padding: 5px 14px; border-radius: 8px; font-size: 0.82rem; font-weight: 600;
    border: 1.5px solid #fca5a5; background: #fff; color: #ef4444; cursor: pointer;
    transition: all 0.15s;
  }
  .btn-sm-danger:hover { background: #ef4444; color: #fff; }

  .empty-state { text-align: center; padding: 5rem 0; }
  .empty-state i { font-size: 3.5rem; color: #e3e5ec; margin-bottom: 1rem; }
  .empty-state h3 { color: #4b5563; font-size: 1.2rem; margin-bottom: 0.5rem; }
  .empty-state p { color: #9ca3af; font-size: 0.9rem; }
</style>

<div class="bookings-header">
  <h2>My Bookings</h2>
  <p>Manage your upcoming and past stays</p>
</div>

<% if (bookings.length === 0) { %>
  <div class="empty-state">
    <i class="fa-regular fa-calendar-xmark"></i>
    <h3>No bookings yet</h3>
    <p>Start exploring and book your first stay!</p>
    <a href="/listings" class="hk-btn" style="display:inline-block;margin-top:1.2rem;">Explore Stays</a>
  </div>
<% } else { %>
  <% bookings.forEach(booking => { %>
    <%
      const ci = new Date(booking.checkIn);
      const co = new Date(booking.checkOut);
      const ciStr = ci.toLocaleDateString('en-IN', { day:'numeric', month:'short', year:'numeric' });
      const coStr = co.toLocaleDateString('en-IN', { day:'numeric', month:'short', year:'numeric' });
      const imgUrl = booking.listing?.image?.url || booking.listing?.image || '/images/placeholder.jpg';
    %>
    <div class="booking-card">
      <img src="<%= imgUrl %>" class="booking-thumb" alt="<%= booking.listing?.title %>"
        onerror="this.src='/images/placeholder.jpg'">

      <div class="booking-info">
        <div class="booking-title">
          <a href="/listings/<%= booking.listing?._id %>" style="color:inherit;text-decoration:none;">
            <%= booking.listing?.title || 'Listing unavailable' %>
          </a>
        </div>
        <div class="booking-location">
          <i class="fa-solid fa-location-dot" style="color:var(--primary);font-size:0.75rem;"></i>
          <%= booking.listing?.location %>, <%= booking.listing?.country %>
        </div>
        <div class="booking-dates">
          <i class="fa-regular fa-calendar" style="color:#6b7280;margin-right:4px;"></i>
          <%= ciStr %> → <%= coStr %>
          &nbsp;·&nbsp; <%= booking.nights %> night<%= booking.nights !== 1 ? 's' : '' %>
          &nbsp;·&nbsp; <%= booking.guests %> guest<%= booking.guests !== 1 ? 's' : '' %>
        </div>
        <div class="booking-meta">
          <span class="status-badge status-<%= booking.paymentStatus === 'paid' ? (booking.status || 'upcoming') : booking.paymentStatus %>">
            <%= booking.paymentStatus === 'paid' ? (booking.status || 'upcoming') : booking.paymentStatus %>
          </span>
          <span class="booking-price">₹<%= booking.totalPrice?.toLocaleString('en-IN') %></span>
        </div>

        <div class="booking-actions">
          <a href="/bookings/<%= booking._id %>" class="btn-sm-outline">View Details</a>
          <% if (booking.status === 'upcoming' && booking.paymentStatus === 'paid') { %>
            <form method="POST" action="/bookings/<%= booking._id %>/cancel"
              onsubmit="return confirm('Cancel this booking?');" style="display:inline;">
              <button type="submit" class="btn-sm-danger">Cancel</button>
            </form>
          <% } %>
        </div>
      </div>
    </div>
  <% }) %>
<% } %>
