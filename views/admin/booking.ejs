<% layout('/layouts/boilerplate') -%>
<style>
  .admin-nav { display:flex;gap:10px;flex-wrap:wrap;margin:1.5rem 0; }
  .admin-nav a { padding:8px 20px;border-radius:10px;border:1.5px solid #e3e5ec;text-decoration:none;font-size:0.88rem;font-weight:600;color:#374151;transition:all 0.15s; }
  .admin-nav a:hover,.admin-nav a.active { background:var(--primary);color:#fff;border-color:var(--primary);text-decoration:none; }
  .table-card { background:#fff;border-radius:16px;padding:1.5rem;box-shadow:0 4px 20px rgba(15,23,42,0.06); }
  table { width:100%;border-collapse:collapse;font-size:0.88rem; }
  thead th { padding:8px 12px;text-align:left;font-size:0.78rem;color:#6b7280;font-weight:600;text-transform:uppercase;border-bottom:1px solid #f1f5f9; }
  tbody td { padding:10px 12px;border-bottom:1px solid #f9fafb;color:#374151; }
  tbody tr:hover td { background:#fafafa; }
  .badge { display:inline-block;padding:2px 10px;border-radius:999px;font-size:0.75rem;font-weight:700; }
  .badge-paid { background:#f0fdf4;color:#15803d; }
  .badge-pending { background:#fff7ed;color:#c2410c; }
  .badge-failed { background:#fef2f2;color:#b91c1c; }
  .badge-upcoming { background:#eff6ff;color:#1d4ed8; }
  .badge-cancelled { background:#f9fafb;color:#6b7280; }
</style>

<h2 style="font-size:1.6rem;font-weight:700;margin:1.5rem 0 0.5rem;">Bookings Management</h2>
<div class="admin-nav">
  <a href="/admin/dashboard">Dashboard</a>
  <a href="/admin/users">Users</a>
  <a href="/admin/listings">Listings</a>
  <a href="/admin/bookings" class="active">Bookings</a>
</div>

<div class="table-card">
  <table>
    <thead>
      <tr><th>#</th><th>Guest</th><th>Listing</th><th>Dates</th><th>Guests</th><th>Amount</th><th>Payment</th><th>Status</th></tr>
    </thead>
    <tbody>
      <% bookings.forEach((b, i) => { %>
        <tr>
          <td style="color:#9ca3af;"><%= i+1 %></td>
          <td><strong><%= b.user?.username %></strong><br><span style="color:#9ca3af;font-size:0.78rem;"><%= b.user?.email %></span></td>
          <td style="max-width:160px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><%= b.listing?.title %></td>
          <td style="white-space:nowrap;font-size:0.82rem;">
            <%= new Date(b.checkIn).toLocaleDateString('en-IN',{day:'numeric',month:'short'}) %> →
            <%= new Date(b.checkOut).toLocaleDateString('en-IN',{day:'numeric',month:'short'}) %>
          </td>
          <td><%= b.guests %></td>
          <td><strong>₹<%= b.totalPrice?.toLocaleString('en-IN') %></strong></td>
          <td><span class="badge badge-<%= b.paymentStatus %>"><%= b.paymentStatus %></span></td>
          <td><span class="badge badge-<%= b.status %>"><%= b.status %></span></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>
