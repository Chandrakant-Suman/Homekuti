<% layout('/layouts/boilerplate') -%>

<style>
  .admin-header { margin: 2rem 0 1.5rem; }
  .admin-header h2 { font-size: 1.8rem; font-weight: 700; color: #1f2933; }
  .admin-header p { color: #6b7280; }

  .stat-cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1.2rem; margin-bottom: 2rem; }
  .stat-card {
    background: #fff; border-radius: 16px; padding: 1.5rem;
    box-shadow: 0 4px 20px rgba(15,23,42,0.06); border: 1.5px solid #f1f5f9;
    display: flex; align-items: center; gap: 1rem;
  }
  .stat-icon {
    width: 52px; height: 52px; border-radius: 14px;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.4rem; flex-shrink: 0;
  }
  .icon-pink { background: #fff1f2; color: var(--primary); }
  .icon-blue { background: #eff6ff; color: #2563eb; }
  .icon-green { background: #f0fdf4; color: #16a34a; }
  .icon-amber { background: #fffbeb; color: #d97706; }
  .stat-value { font-size: 1.7rem; font-weight: 700; color: #1f2933; line-height: 1; }
  .stat-label { font-size: 0.82rem; color: #6b7280; margin-top: 3px; }

  .admin-nav { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 2rem; }
  .admin-nav a {
    padding: 8px 20px; border-radius: 10px; border: 1.5px solid #e3e5ec;
    text-decoration: none; font-size: 0.88rem; font-weight: 600; color: #374151;
    transition: all 0.15s;
  }
  .admin-nav a:hover, .admin-nav a.active { background: var(--primary); color: #fff; border-color: var(--primary); text-decoration: none; }

  .table-card { background: #fff; border-radius: 16px; padding: 1.5rem; box-shadow: 0 4px 20px rgba(15,23,42,0.06); }
  .table-card h3 { font-size: 1rem; font-weight: 700; color: #1f2933; margin-bottom: 1rem; }
  table { width: 100%; border-collapse: collapse; font-size: 0.88rem; }
  thead th { padding: 8px 12px; text-align: left; font-size: 0.78rem; color: #6b7280; font-weight: 600; text-transform: uppercase; letter-spacing: 0.04em; border-bottom: 1px solid #f1f5f9; }
  tbody td { padding: 10px 12px; border-bottom: 1px solid #f9fafb; color: #374151; }
  tbody tr:last-child td { border-bottom: none; }
  tbody tr:hover td { background: #fafafa; }
  .badge { display: inline-block; padding: 2px 10px; border-radius: 999px; font-size: 0.75rem; font-weight: 700; }
  .badge-green { background: #f0fdf4; color: #16a34a; }
  .badge-blue { background: #eff6ff; color: #2563eb; }
  .badge-red { background: #fef2f2; color: #b91c1c; }
</style>

<div class="admin-header">
  <h2>⚙️ Admin Dashboard</h2>
  <p>Full control over Homekuti platform</p>
</div>

<div class="admin-nav">
  <a href="/admin/dashboard" class="active">Dashboard</a>
  <a href="/admin/users">Users</a>
  <a href="/admin/listings">Listings</a>
  <a href="/admin/bookings">Bookings</a>
</div>

<!-- Stat cards -->
<div class="stat-cards">
  <div class="stat-card">
    <div class="stat-icon icon-blue"><i class="fa-solid fa-users"></i></div>
    <div>
      <div class="stat-value"><%= totalUsers %></div>
      <div class="stat-label">Total Users</div>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon icon-pink"><i class="fa-solid fa-house"></i></div>
    <div>
      <div class="stat-value"><%= totalListings %></div>
      <div class="stat-label">Total Listings</div>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon icon-green"><i class="fa-solid fa-calendar-check"></i></div>
    <div>
      <div class="stat-value"><%= totalBookings %></div>
      <div class="stat-label">Paid Bookings</div>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon icon-amber"><i class="fa-solid fa-indian-rupee-sign"></i></div>
    <div>
      <div class="stat-value">₹<%= (totalRevenue/1000).toFixed(1) %>k</div>
      <div class="stat-label">Total Revenue</div>
    </div>
  </div>
</div>

<!-- Recent bookings -->
<div class="table-card">
  <h3>Recent Bookings</h3>
  <% if (recentBookings.length === 0) { %>
    <p style="color:#9ca3af;font-style:italic;font-size:0.9rem;">No bookings yet.</p>
  <% } else { %>
    <table>
      <thead>
        <tr>
          <th>Guest</th>
          <th>Listing</th>
          <th>Amount</th>
          <th>Status</th>
          <th>Date</th>
        </tr>
      </thead>
      <tbody>
        <% recentBookings.forEach(b => { %>
          <tr>
            <td><strong><%= b.user?.username %></strong><br><span style="color:#9ca3af;font-size:0.78rem;"><%= b.user?.email %></span></td>
            <td><%= b.listing?.title %></td>
            <td><strong>₹<%= b.totalPrice?.toLocaleString('en-IN') %></strong></td>
            <td><span class="badge badge-green"><%= b.paymentStatus %></span></td>
            <td><%= new Date(b.createdAt).toLocaleDateString('en-IN') %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</div>


<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<div class="row mt-5">

  <!-- Revenue Chart -->
  <div class="col-md-6">
    <canvas id="revenueChart"></canvas>
  </div>

  <!-- User Growth -->
  <div class="col-md-6">
    <canvas id="userChart"></canvas>
  </div>

</div>

<div class="row mt-5">
  <div class="col-md-12">
    <canvas id="listingChart"></canvas>
  </div>
</div>

<script>
  const revenueData = <%- JSON.stringify(revenueTrend || []) %>;
const userData = <%- JSON.stringify(userGrowth || []) %>;
const listingData = <%- JSON.stringify(bookingsPerListing || []) %>;

  // Revenue Chart
  new Chart(document.getElementById("revenueChart"), {
    type: "line",
    data: {
      labels: revenueData.map(d => d._id),
      datasets: [{
        label: "Revenue",
        data: revenueData.map(d => d.revenue),
        borderWidth: 2
      }]
    }
  });

  // User Growth Chart
  new Chart(document.getElementById("userChart"), {
    type: "bar",
    data: {
      labels: userData.map(d => d._id),
      datasets: [{
        label: "Users",
        data: userData.map(d => d.users)
      }]
    }
  });

  // Top Listings Chart
  new Chart(document.getElementById("listingChart"), {
    type: "doughnut",
    data: {
      labels: listingData.map(d => d.title),
      datasets: [{
        data: listingData.map(d => d.count)
      }]
    }
  });
</script>