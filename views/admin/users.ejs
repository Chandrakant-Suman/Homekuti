<% layout('/layouts/boilerplate') -%>
<style>
  .admin-nav { display:flex;gap:10px;flex-wrap:wrap;margin:1.5rem 0; }
  .admin-nav a { padding:8px 20px;border-radius:10px;border:1.5px solid #e3e5ec;text-decoration:none;font-size:0.88rem;font-weight:600;color:#374151;transition:all 0.15s; }
  .admin-nav a:hover,.admin-nav a.active { background:var(--primary);color:#fff;border-color:var(--primary);text-decoration:none; }
  .table-card { background:#fff;border-radius:16px;padding:1.5rem;box-shadow:0 4px 20px rgba(15,23,42,0.06); }
  table { width:100%;border-collapse:collapse;font-size:0.88rem; }
  thead th { padding:8px 12px;text-align:left;font-size:0.78rem;color:#6b7280;font-weight:600;text-transform:uppercase;letter-spacing:0.04em;border-bottom:1px solid #f1f5f9; }
  tbody td { padding:10px 12px;border-bottom:1px solid #f9fafb;color:#374151; }
  tbody tr:hover td { background:#fafafa; }
  .badge { display:inline-block;padding:2px 10px;border-radius:999px;font-size:0.75rem;font-weight:700; }
  .badge-user { background:#eff6ff;color:#1d4ed8; }
  .badge-owner { background:#f0fdf4;color:#15803d; }
  .badge-admin { background:#fef3c7;color:#92400e; }
  select.role-sel { border:1.5px solid #e3e5ec;border-radius:8px;padding:4px 8px;font-size:0.82rem;font-family:inherit;cursor:pointer; }
  .btn-del { background:none;border:1.5px solid #fca5a5;border-radius:8px;color:#ef4444;padding:4px 12px;cursor:pointer;font-size:0.8rem;font-weight:600;transition:all 0.15s; }
  .btn-del:hover { background:#ef4444;color:#fff; }
</style>

<h2 style="font-size:1.6rem;font-weight:700;margin:1.5rem 0 0.5rem;">Users Management</h2>
<div class="admin-nav">
  <a href="/admin/dashboard">Dashboard</a>
  <a href="/admin/users" class="active">Users</a>
  <a href="/admin/listings">Listings</a>
  <a href="/admin/bookings">Bookings</a>
</div>

<div class="table-card">
  <table>
    <thead>
      <tr><th>#</th><th>Username</th><th>Email</th><th>Role</th><th>Joined</th><th>Actions</th></tr>
    </thead>
    <tbody>
      <% users.forEach((u, i) => { %>
        <tr>
          <td style="color:#9ca3af;"><%= i+1 %></td>
          <td><strong><%= u.username %></strong></td>
          <td style="color:#6b7280;"><%= u.email %></td>
          <td>
            <form method="POST" action="/admin/users/<%= u._id %>/role" style="display:inline;">
              <select name="role" class="role-sel" onchange="this.form.submit()">
                <option value="user" <%= u.role === 'user' ? 'selected' : '' %>>User</option>
                <option value="owner" <%= u.role === 'owner' ? 'selected' : '' %>>Owner</option>
                <option value="admin" <%= u.role === 'admin' ? 'selected' : '' %>>Admin</option>
              </select>
            </form>
          </td>
          <td><%= new Date(u.createdAt).toLocaleDateString('en-IN') %></td>
          <td>
            <form method="POST" action="/admin/users/<%= u._id %>?_method=DELETE"
              onsubmit="return confirm('Delete this user?');">
              <button type="submit" class="btn-del">Delete</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>
