<% layout('/layouts/boilerplate') -%>
<style>
  .form-card { background:#fff; border-radius:20px; padding:2.5rem; box-shadow:0 8px 40px rgba(15,23,42,0.08); max-width:680px; margin:2rem auto; }
  .form-title { font-size:1.7rem; font-weight:700; margin-bottom:1.8rem; color:#1f2933; }
  .form-label { font-size:0.87rem; font-weight:600; color:#374151; margin-bottom:5px; display:block; }
  .form-control { border:1.5px solid #e3e5ec; border-radius:10px; font-family:inherit; }
  .form-control:focus { border-color:var(--primary); box-shadow:none; }
  .current-img { width:100%; max-height:200px; object-fit:cover; border-radius:10px; margin-bottom:8px; }
</style>

<div class="form-card">
  <h2 class="form-title">Edit Listing</h2>
  <form method="POST" action="/listings/<%= listing._id %>?_method=PUT" class="needs-validation" novalidate enctype="multipart/form-data">

    <div class="mb-3">
      <label class="form-label">Title *</label>
      <input type="text" required minlength="3" class="form-control" name="listing[title]" value="<%= listing.title %>">
      <div class="invalid-feedback">Title required (min 3 chars).</div>
    </div>

    <div class="mb-3">
      <label class="form-label">Description *</label>
      <textarea class="form-control" name="listing[description]" rows="4" required minlength="10"><%= listing.description %></textarea>
      <div class="invalid-feedback">Description required (min 10 chars).</div>
    </div>

    <div class="mb-3">
      <label class="form-label">Current Image</label>
      <img src="<%= listing.image?.url || listing.image %>" alt="Current" class="current-img">
      <label class="form-label mt-2">Upload New Image (optional)</label>
      <input type="file" class="form-control" name="listing[image]" accept="image/*">
    </div>

    <div class="row g-3 mb-3">
      <div class="col-md-4">
        <label class="form-label">Price / night (₹) *</label>
        <input type="number" class="form-control" name="listing[price]" min="1" value="<%= listing.price %>" required>
        <div class="invalid-feedback">Min ₹1</div>
      </div>
      <div class="col-md-8">
        <label class="form-label">Location *</label>
        <input type="text" required class="form-control" name="listing[location]" value="<%= listing.location %>">
        <div class="invalid-feedback">Location required.</div>
      </div>
    </div>

    <div class="row g-3 mb-3">
      <div class="col-md-6">
        <label class="form-label">Country *</label>
        <input type="text" required class="form-control" name="listing[country]" value="<%= listing.country %>">
        <div class="invalid-feedback">Country required.</div>
      </div>
      <div class="col-md-6">
        <label class="form-label">Genre</label>
        <select class="form-control form-select" name="listing[genre]">
          <option value="">Select genre</option>
          <% genres.forEach(g => { %>
            <option value="<%= g %>" <%= listing.genre === g ? 'selected' : '' %>><%= g %></option>
          <% }) %>
        </select>
      </div>
    </div>

    <div class="d-grid mt-4">
      <button class="hk-btn" type="submit" style="height:48px;font-size:1rem;">Update Listing</button>
    </div>
  </form>
</div>
