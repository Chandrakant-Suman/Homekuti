<% layout('/layouts/boilerplate') -%>

<style>
  .signin-wrapper {
    min-height: calc(100vh - 72px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 1rem;
  }
  .signin-card {
    background: #fff;
    border-radius: 20px;
    padding: 2.5rem 2.2rem;
    width: 100%;
    max-width: 480px;
    box-shadow: 0 20px 60px rgba(15, 23, 42, 0.08);
  }
  .signin-title { font-size: 2rem; font-weight: 700; text-align: center; color: #1f2933; margin-bottom: 2rem; }
  .signin-label { font-size: 0.9rem; font-weight: 600; color: #374151; margin-bottom: 6px; display: block; }
  .signin-input {
    width: 100%; border: 1.5px solid #e3e5ec; border-radius: 10px;
    padding: 12px 16px; font-size: 0.95rem; font-family: inherit;
    color: #1f2933; background: #fff; outline: none; transition: border-color 0.2s; box-sizing: border-box;
  }
  .signin-input::placeholder { color: #9ca3af; }
  .signin-input:focus { border-color: var(--primary); }
  .mb-form { margin-bottom: 1.2rem; }
  .signin-btn {
    width: 100%; height: 50px; background: var(--primary); color: #fff;
    border: none; border-radius: 10px; font-size: 1rem; font-weight: 700;
    cursor: pointer; transition: background 0.2s; margin-top: 0.5rem;
  }
  .signin-btn:hover { background: var(--primary-dark); }
  .signin-footer { text-align: center; margin-top: 1.4rem; font-size: 0.9rem; color: #6b7280; }
  .signin-footer a { color: var(--primary); font-weight: 600; text-decoration: none; }
</style>

<div class="signin-wrapper">
  <div class="signin-card">
    <h2 class="signin-title">Create Account</h2>

    <form action="/user/signup" method="POST" novalidate>
      <div class="mb-form">
        <label class="signin-label">Username</label>
        <input type="text" class="signin-input" name="username" placeholder="Choose a username" required />
      </div>
      <div class="mb-form">
        <label class="signin-label">Email</label>
        <input type="email" class="signin-input" name="email" placeholder="Enter your email" required />
      </div>
      <div class="mb-form">
        <label class="signin-label">Password</label>
        <input type="password" class="signin-input" name="password" placeholder="Create a password" required minlength="6" />
      </div>
      <button type="submit" class="signin-btn">Create Account</button>
    </form>

    <div class="signin-footer">
      Already have an account? <a href="/user/signin">Sign in</a>
    </div>
  </div>
</div>
