<% layout('/layouts/boilerplate') -%>

<!-- hero section -->
<section class="hk-hero offset-1">
  <div class="hk-hero-content">
    <p class="hk-hero-kicker">Curated homestays • Cozy cottages • Mountain escapes</p>
    <h1 class="hk-hero-title">Find a stay that actually feels like home.</h1>
    <p class="hk-hero-subtitle">
      Discover handpicked homes, cabins, and rooms hosted by people who care.
      No generic hotel vibe, just warm, lived-in spaces.
    </p>
    <div class="hk-hero-actions">
      <a href="/listings" class="hk-btn">Explore all stays</a>
      <a href="/listings/new" class="hk-btn">Become a host</a>
    </div>
  </div>

<div class="hk-hero-side d-none d-md-block">

  <% if (bestDeal) { %>
    <a href="/listings/<%= bestDeal._id %>" style="text-decoration:none;color:inherit;">
      <div class="hk-hero-card">

        <h3>
          Top Rated in <%= bestDeal.location || "India" %>
        </h3>

        <p>
          <%= bestDeal.title || "Cozy stay" %>
        </p>

        <span class="hk-hero-tag">
          ⭐ <%= bestDeal.avgRating?.toFixed ? bestDeal.avgRating.toFixed(1) : bestDeal.avgRating %>
          • ₹<%= bestDeal.price ? Number(bestDeal.price).toLocaleString("en-IN") : "N/A" %>/night
        </span>

      </div>
    </a>

  <% } else { %>

    <div class="hk-hero-card">
      <h3>Explore stays</h3>
      <p>Find cozy and highly rated places across India.</p>
      <span class="hk-hero-tag">Browse listings</span>
    </div>

  <% } %>

</div>
</section>

<!-- search section -->

<div class="hk-search-wrapper">
  <%- include("./partials/search") %>
</div>

<!-- Featured Stays -->
<section class="hk-section">
  <div class="hk-section-header">
    <h2>Featured stays</h2>
    <a href="/listings"><strong>View all</strong></a>
  </div>

  <div class="row g-4">
    <% if (featuredListings && featuredListings.length) { %>
      <% featuredListings.forEach(listing => { %>
        <div class="col-md-4">
          <div class="hk-stay-card position-relative">
            <a href="/listings/<%= listing._id %>" class="stretched-link" style="z-index:2;"></a>
            <%
              let displayImage = "/images/placeholder.jpg";
              if (listing.image) {
                if (typeof listing.image === "string") displayImage = listing.image;
                else if (listing.image.url) displayImage = listing.image.url;
              }
            %>
            <div class="hk-stay-image" style="background-image:url('<%= displayImage %>')">
              <% if (listing.genre) { %>
                <span style="position:absolute;top:10px;left:10px;background:rgba(0,0,0,0.5);color:#fff;padding:2px 10px;border-radius:999px;font-size:0.72rem;font-weight:600;backdrop-filter:blur(4px);">
                  <%= listing.genre %>
                </span>
              <% } %>
            </div>
            <div class="hk-stay-body">
              <p class="hk-stay-location"><%= listing.location || "Location" %>, <%= listing.country || "India" %></p>
              <p class="hk-stay-title"><%= listing.title || "Untitled" %></p>
              <div style="display:flex;justify-content:space-between;align-items:center;">
                <p class="hk-stay-price" style="margin:0;">
                  <span>₹<%= listing.price ? Number(listing.price).toLocaleString("en-IN") : "N/A" %></span> /night
                </p>
                <% if (listing.avgRating > 0) { %>
                  <span style="font-size:0.82rem;font-weight:600;display:flex;align-items:center;gap:3px;">
                    <i class="fa-solid fa-star" style="color:#f59e0b;font-size:0.75rem;"></i>
                    <%= listing.avgRating.toFixed ? listing.avgRating.toFixed(1) : listing.avgRating %>
                  </span>
                <% } %>
              </div>
            </div>
          </div>
        </div>
      <% }) %>
    <% } else { %>
      <div class="col-12 text-center py-5">
        <p style="color:#6b7280;">No featured stays available right now.</p>
        <a href="/listings" class="hk-btn" style="display:inline-block;margin-top:1rem;">Browse all listings</a>
      </div>
    <% } %>
  </div>
</section>
